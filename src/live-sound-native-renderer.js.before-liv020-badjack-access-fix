    const normalizedKey = sfLiv020PairKey(pair.fromKey, pair.toKey);

    if (baseValid) {
      return {
        allowed: true,
        valid: true,
        key: normalizedKey
      };
    }

    if (sfLiv020IsCuratedBadPair(pair.fromKey, pair.toKey)) {
