  function sfLiv020RouteDecision(fromNode, toNode, baseValid, baseKey) {
    if (LEVEL_ID !== "LIV-020") {
      return {
        allowed: baseValid,
        valid: baseValid,
        key: baseKey
      };
    }

    const pair = sfLiv020NormalizeOutputInputPair(
      fromNode && fromNode.key,
      toNode && toNode.key
    );

    if (!pair) {
      return {
        allowed: baseValid,
        valid: baseValid,
        key: baseKey
      };
