      .filter(isUsableNativeBoardSurface)
      .sort((a, b) => {
        const score = el => (el.id === "patchbay" ? 3 : el.classList.contains("patchbay-wrap") ? 2 : 1) * 10000000 + areaOf(el);
        return score(b) - score(a);
      })[0];

