    const midY = Math.min(from.y, to.y) - lift;

    const p0 = from;
    const p1 = { x: from.x, y: midY };
    const p2 = { x: to.x, y: midY };
    const p3 = to;

    let best = Infinity;
    for (let i = 0; i <= 48; i++) {
      const p = cubicPoint(p0, p1, p2, p3, i / 48);
