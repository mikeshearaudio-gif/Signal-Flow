      }
      createLabel(layer, "MAIN PA AMPLIFIER", level.rect.width * 0.600, level.rect.height * 0.550, 12);
    } else {
      createLabel(layer, "SOURCE", level.rect.width * 0.060, level.rect.height * 0.100, 12);
